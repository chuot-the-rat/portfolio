    "overview": {
        "title": "Project Overview",
        "description": "A motion graphics project created for an in-class assignment, bringing the colorful characters and playful energy of Super Auto Pets to life through animated illustrations. The project explores character animation, timing, and visual storytelling through the lens of one of the most engaging deck-building roguelike games.",
        "images": []
    },
    "inspiration": {
        "title": "Inspiration: Super Auto Pets",
        "description": "Super Auto Pets is a strategic deck-building game where players collect and combine adorable creatures to build the ultimate auto-battling team. The game's charming art style, expressive character designs, and strategic depth served as the foundation for this motion project. Each pet has distinct personality and mechanics, making them perfect subjects for animation.",
        "images": []
    },
    "design": {
        "title": "Design & Animation Process",
        "description": "Using Adobe Illustrator, character illustrations and UI elements were created with attention to the game's distinctive aesthetic. These designs were then brought to life in After Effects through keyframe animation, exploring movement, timing, and personality-driven motion.",
        "images": []
    },
